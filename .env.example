# ── Docker Compose (локально обязательно dev-профиль) ─────────────────────────
# Без этого поднимется только PostgreSQL. Для Dokploy задайте COMPOSE_PROFILES=prod
COMPOSE_PROFILES=dev

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/vacation_planner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
BACKEND_CORS_ORIGINS=http://localhost:5173

# ── Frontend (prod only) ──────────────────────────────────────────────────────
VITE_API_URL=/api
